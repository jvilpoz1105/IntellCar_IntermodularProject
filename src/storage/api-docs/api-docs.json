                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/adverts": {
            "get": {
                "tags": [
                    "Anuncios"
                ],
                "summary": "Obtener listado de anuncios",
                "operationId": "c7d8b1b820c2cbd05e6e9e21b721e80e",
                "parameters": [
                    {
                        "name": "visible",
                        "in": "query",
                        "description": "Filtrar por visibilidad (solo anuncios visibles)",
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "ad_type",
                        "in": "query",
                        "description": "Filtrar por tipo de anuncio",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "new",
                                "km0",
                                "used",
                                "renting",
                                "leasing",
                                "supcription"
                            ]
                        }
                    },
                    {
                        "name": "min_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "max_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Listado de anuncios",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/CarAdvert"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Anuncios"
                ],
                "summary": "Crear un nuevo anuncio",
                "operationId": "df80eb1fd39e2b76c4db494abe28b1cb",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "ad_title",
                                    "ad_type",
                                    "price",
                                    "model_id",
                                    "engine_id",
                                    "car_color",
                                    "region",
                                    "city"
                                ],
                                "properties": {
                                    "ad_title": {
                                        "type": "string"
                                    },
                                    "ad_type": {
                                        "type": "string",
                                        "enum": [
                                            "new",
                                            "km0",
                                            "used",
                                            "renting",
                                            "leasing",
                                            "supcription"
                                        ]
                                    },
                                    "price": {
                                        "type": "number"
                                    },
                                    "model_id": {
                                        "type": "integer"
                                    },
                                    "engine_id": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Anuncio creado"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
