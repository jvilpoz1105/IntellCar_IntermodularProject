    "components": {
        "schemas": {
            "AppUser": {
                "properties": {
                    "user_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "user_name": {
                        "type": "string",
                        "example": "Juan Perez"
                    },
                    "email_address": {
                        "type": "string",
                        "format": "email",
                        "example": "juan@example.com"
                    },
                    "phone": {
                        "type": "string",
                        "example": "+34600000000"
                    },
                    "user_tag": {
                        "type": "string",
                        "example": "indv"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "CarAdvert": {
                "properties": {
                    "ad_id": {
                        "type": "integer",
                        "example": 10
                    },
                    "ad_title": {
                        "type": "string",
                        "example": "BMW Serie 3 320d"
                    },
                    "ad_type": {
                        "type": "string",
                        "example": "used"
                    },
                    "price": {
                        "type": "number",
                        "format": "float",
                        "example": 23990
                    },
                    "car_color": {
                        "type": "string",
                        "example": "gris"
                    },
                    "region": {
                        "type": "string",
                        "example": "Madrid"
                    },
                    "city": {
                        "type": "string",
                        "example": "Alcobendas"
                    },
                    "visible": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
